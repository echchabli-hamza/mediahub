    {
      "name": "🏥 Health Checks",
      "item": [
        {
          "name": "Eureka Server",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8761",
              "host": ["http://localhost:8761"]
            }
          }
        },
        {
          "name": "Config Server Health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8888/actuator/health",
              "host": ["http://localhost:8888"],
              "path": ["actuator", "health"]
            }
          }
        },
        {
          "name": "Gateway Health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:7001/actuator/health",
              "host": ["http://localhost:7001"],
